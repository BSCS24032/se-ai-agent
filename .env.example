# =========================================================
# AI Research Agent - V1 - environment configuration
# =========================================================
# Copy this file to `.env` and fill in real values.
# `.env` is gitignored so your keys never get committed.

# ---- LLM provider ----
# One of: "groq" (recommended, free tier), "ollama" (fully local),
#         "openai" (OpenAI-compatible endpoint), "none" (no LLM, raw query only)
LLM_PROVIDER=groq

# Groq API key - get a free one at https://console.groq.com/keys
# Free tier is generous and runs Llama 3.x at high speed.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Ollama (local) settings - only needed if LLM_PROVIDER=ollama
# Install Ollama from https://ollama.com then run: ollama pull llama3.1
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# OpenAI-compatible endpoint - only needed if LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ---- NCBI / PubMed ----
# Optional. Providing an email + (optional) API key gives you a higher
# rate limit and is recommended by NCBI's usage policy.
# Get a free API key at https://www.ncbi.nlm.nih.gov/account/settings/
NCBI_EMAIL=your-email@example.com
NCBI_API_KEY=

# ---- Pipeline tuning ----
MAX_ARTICLES=10
REQUEST_TIMEOUT_SECONDS=30
